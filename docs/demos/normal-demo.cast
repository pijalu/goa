[11.833, "o", "\u001b[?2026h\u001b[30;1H\u001b[49m          \u001b[38;5;80;49m\u00e2\u0096\u0084\u00e2\u0096\u0084\u00e2\u0096\u0084\u001b[38;5;80;48;5;0m\u00e2\u0096\u0084\u00e2\u0096\u0084\u001b[48;5;80m      \u001b[38;5;80;48;5;0m\u00e2\u0096\u0084\u00e2\u0096\u0084\u001b[38;5;80;49m\u00e2\u0096\u0084\u00e2\u0096\u0084\u001b[38;5;0;49m\u00e2\u0096\u0084\u001b[49m         \u001b[m    \u00e2\u0096\u0084\u00e2\u0096\u0084\u00e2\u0096\u0084\u00e2\u0096\u0084\u00e2\u0096\u0084\u00e2\u0096\u0084      \u00e2\u0096\u0084\u00e2\u0096\u0084\u00e2\u0096\u0084\u00e2\u0096\u0084      \u00e2\u0096\u0084\u00e2\u0096\u0084\u00e2\u0096\u0084\u00e2\u0096\u0084                                   \u001b[0m\u001b]8;;\u0007\r\n\u001b[49m  \u001b[38;5;0;49m\u00e2\u0096\u0084\u001b[38;5;80;49m\u00e2\u0096\u0084\u00e2\u0096\u0084\u00e2\u0096\u0084\u001b[38;5;0;49m\u00e2\u0096\u0084\u001b[38;5;80;49m\u00e2\u0096\u0084\u001b[48;5;80m \u001b[38;5;0;48;5;80m\u00e2\u0096\u0084\u001b[38;5;15;48;5;80m\u00e2\u0096\u0084\u00e2\u0096\u0084\u00e2\u0096\u0084\u001b[38;5;0;48;5;80m\u00e2\u0096\u0084\u001b[48;5;80m      \u001b[38;5;15;48;5;80m\u00e2\u0096\u0084\u00e2\u0096\u0084\u00e2\u0096\u0084\u00e2\u0096\u0084\u00e2\u0096\u0084\u001b[38;5;80;48;5;80m\u00e2\u0096\u0084\u001b[48;5;80m \u001b[38;5;80;49m\u00e2\u0096\u0084\u001b[38;5;80;48;5;0m\u00e2\u0096\u0084\u001b[48;5;80m  \u001b[38;5;80;49m\u00e2\u0096\u0084\u001b[38;5;0;49m\u00e2\u0096\u0084\u001b[49m  \u001b[m  \u00e2\u0096\u0084\u00e2\u0096\u0088\u00e2\u0096\u0088\u00e2\u0096\u0088 \u00e2\u0096\u0088\u00e2\u0096\u0088\u00e2\u0096\u0088\u00e2\u0096\u0088 \u00e2\u0096\u0084\u00e2\u0096\u0088\u00e2\u0096\u0088\u00e2\u0096\u0088 \u00e2\u0096\u0088\u00e2\u0096\u0088\u00e2\u0096\u0088\u00e2\u0096\u0088 \u00e2\u0096\u0084\u00e2\u0096\u0088\u00e2\u0096\u0088\u00e2\u0096\u0088 \u00e2\u0096\u0088\u00e2\u0096\u0088\u00e2\u0096\u0088\u00e2\u0096\u0088                                  \u001b[0m\u001b]8;;\u0007\r\n\u001b[49m \u001b[38;5;80;48;5;0m\u00e2\u0096\u0084\u001b[48;5;80m \u001b[38;5;0;48;5;80m\u00e2\u0096\u0084\u00e2\u0096\u0084\u001b[38;5;80;48;5;0m\u00e2\u0096\u0084\u001b[48;5;80m \u001b[38;5;15;48;5;80m\u00e2\u0096\u0084\u001b[48;5;15m       \u001b[38;5;238;48;5;80m\u00e2\u0096\u0084\u001b[48;5;80m  \u001b[38;5;15;48;5;80m\u00e2\u0096\u0084\u001b[48;5;15m       \u001b[38;5;255;48;5;80m\u00e2\u0096\u0084\u001b[48;5;80m  \u001b[38;5;80;48;5;0m\u00e2\u0096\u0084\u001b[38;5;0;48;5;80m\u00e2\u0096\u0084\u001b[48;5;80m  \u001b[49m  \u001b[m  \u00e2\u0096\u0088\u00e2\u0096\u0088\u00e2"]
[11.833, "o", "\u0096\u0088\u00e2\u0096\u0088 \u00e2\u0096\u0088\u00e2\u0096\u0088\u00e2\u0096\u0088\u00e2\u0096\u0088 \u00e2\u0096\u0088\u00e2\u0096\u0088\u00e2\u0096\u0088\u00e2\u0096\u0088 \u00e2\u0096\u0088\u00e2\u0096\u0088\u00e2\u0096\u0088\u00e2\u0096\u0088 \u00e2\u0096\u0088\u00e2\u0096\u0088\u00e2\u0096\u0088\u00e2\u0096\u0088 \u00e2\u0096\u0088\u00e2\u0096\u0088\u00e2\u0096\u0088\u00e2\u0096\u0088                                  \u001b[0m\u001b]8;;\u0007\r\n\u001b[49m \u001b[38;5;0;48;5;80m\u00e2\u0096\u0084\u001b[48;5;80m \u001b[38;5;80;48;5;0m\u00e2\u0096\u0084\u001b[38;5;80;48;5;238m\u00e2\u0096\u0084\u001b[48;5;80m  \u001b[48;5;15m \u001b[48;5;0m  \u001b[48;5;15m      \u001b[48;5;80m  \u001b[48;5;15m \u001b[48;5;0m \u001b[38;5;15;48;5;0m\u00e2\u0096\u0084\u001b[48;5;15m      \u001b[48;5;80m   \u001b[38;5;0;48;5;80m\u00e2\u0096\u0084\u001b[48;5;80m \u001b[38;5;0;48;5;80m\u00e2\u0096\u0084\u001b[49m  \u001b[m  \u00e2\u0096\u0088\u00e2\u0096\u0088\u00e2\u0096\u0088\u00e2\u0096\u0088 \u00e2\u0096\u0088\u00e2\u0096\u0088\u00e2\u0096\u0088\u00e2\u0096\u0088 \u00e2\u0096\u0088\u00e2\u0096\u0088\u00e2\u0096\u0088\u00e2\u0096\u0088 \u00e2\u0096\u0088\u00e2\u0096\u0088\u00e2\u0096\u0088\u00e2\u0096\u0088 \u00e2\u0096\u0084\u00e2\u0096\u0084\u00e2\u0096\u0084\u00e2\u0096\u0084\u00e2\u0096\u0084\u00e2\u0096\u0088\u00e2\u0096\u0088\u00e2\u0096\u0088\u00e2\u0096\u0088                                  \u001b[0m\u001b]8;;\u0007\r\n\u001b[49m  \u001b[49;38;5;0m\u00e2\u0096\u0080\u001b[38;5;80;48;5;0m\u00e2\u0096\u0084\u001b[48;5;80m   \u001b[38;5;0;48;5;15m\u00e2\u0096\u0084\u001b[38;5;15;48;5;0m\u00e2\u0096\u0084\u00e2\u0096\u0084\u001b[48;5;15m     \u001b[38;5;80;48;5;0m\u00e2\u0096\u0084\u001b[48;5;80m  \u001b[38;5;80;48;5;15m\u00e2\u0096\u0084\u001b[48;5;15m \u001b[38;5;15;48;5;0m\u00e2\u0096\u0084\u001b[48;5;15m     \u001b[38;5;80;48;5;0m\u00e2\u0096\u0084\u001b[48;5;80m    \u001b[49m    \u001b[m  \u00e2\u0096\u0080\u00e2\u0096\u0088\u00e2\u0096\u0088\u00e2\u0096