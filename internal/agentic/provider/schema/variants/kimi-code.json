{
  "id": "kimi-code",
  "match": { "api": "openai-completions", "provider": "kimi-code" },
  "defaults": {
    "temperature": 1.0,
    "max_tokens": 4096,
    "thinking": "max",
    "thinking_level_map": {
      "minimal": "max",
      "low": "max",
      "medium": "max",
      "high": "max",
      "xhigh": "max",
      "max": "max"
    }
  },
  "compat": {
    "supports_store": false,
    "max_tokens_field": "max_tokens",
    "thinking_format": "openai",
    "supports_prompt_cache": false,
    "stream_includes_usage": true
  },
  "auth": {
    "method": "api_key",
    "env_vars": ["KIMI_CODE_API_KEY", "MOONSHOT_API_KEY"],
    "header": "Authorization",
    "prefix": "Bearer "
  },
  "cache_policy": { "mode": "none", "breakpoint_cap": 0 },
  "tool_compat": {
    "tool_call_id_rules": { "max_length": 40, "alphabet": "[a-zA-Z0-9_-]" },
    "schema_sanitizer": "moonshot",
    "supports_parallel_tool_calls": true
  },
  "error_rules": { "retryable_statuses": [429, 500, 502, 503, 504] }
}
