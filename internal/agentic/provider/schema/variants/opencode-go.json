{
  "id": "opencode-go",
  "match": { "api": "openai-completions", "provider": "opencode-go" },
  "defaults": { "temperature": 1.0, "max_tokens": 8192 },
  "compat": {
    "supports_store": false,
    "max_tokens_field": "max_tokens",
    "thinking_format": "deepseek",
    "requires_reasoning_content_on_assistant_messages": true,
    "supports_prompt_cache": false,
    "stream_includes_usage": false
  },
  "auth": {
    "method": "api_key",
    "required": true,
    "env_vars": ["OPENCODE_API_KEY"],
    "header": "Authorization",
    "prefix": "Bearer "
  },
  "cache_policy": { "mode": "none", "breakpoint_cap": 0 },
  "tool_compat": {
    "tool_call_id_rules": { "max_length": 40, "alphabet": "[a-zA-Z0-9_-]" },
    "schema_sanitizer": "openai",
    "supports_parallel_tool_calls": true
  },
  "error_rules": {
    "retryable_statuses": [429, 500, 502, 503, 504],
    "context_overflow_patterns": [
      "greater than the context length"
    ]
  }
}
