{
  "id": "google-base",
  "match": { "api": "google-generative-ai", "provider": "google" },
  "defaults": { "temperature": 1.0, "max_tokens": 8192 },
  "compat": {
    "supports_store": false,
    "max_tokens_field": "max_output_tokens",
    "thinking_format": "reasoning_content",
    "supports_prompt_cache": false,
    "stream_includes_usage": true,
    "image_detail_supported": true
  },
  "auth": {
    "method": "api_key",
    "env_vars": ["GOOGLE_API_KEY", "GEMINI_API_KEY"],
    "header": "x-goog-api-key",
    "prefix": ""
  },
  "cache_policy": { "mode": "none", "breakpoint_cap": 0 },
  "tool_compat": {
    "tool_call_id_rules": { "max_length": 40, "alphabet": "[a-zA-Z0-9_-]" },
    "schema_sanitizer": "gemini",
    "supports_parallel_tool_calls": false
  },
  "error_rules": { "retryable_statuses": [429, 500, 502, 503, 504] }
}
