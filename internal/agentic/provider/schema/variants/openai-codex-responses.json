{
  "id": "openai-codex-responses",
  "match": { "api": "openai-codex-responses", "provider": "openai" },
  "defaults": { "temperature": 1.0, "max_tokens": 4096 },
  "compat": {
    "supports_store": true,
    "max_tokens_field": "max_output_tokens",
    "thinking_format": "reasoning_content",
    "supports_prompt_cache": false,
    "stream_includes_usage": true
  },
  "auth": {
    "method": "api_key",
    "env_vars": ["OPENAI_API_KEY"],
    "header": "Authorization",
    "prefix": "Bearer "
  },
  "cache_policy": { "mode": "none", "breakpoint_cap": 0 },
  "tool_compat": {
    "tool_call_id_rules": { "max_length": 40, "alphabet": "[a-zA-Z0-9_-]" },
    "schema_sanitizer": "openai",
    "supports_parallel_tool_calls": true
  },
  "error_rules": { "retryable_statuses": [429, 500, 502, 503, 504] }
}
