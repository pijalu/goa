{
  "id": "lm-studio",
  "match": { "api": "openai-completions", "provider": "lm-studio" },
  "defaults": { "temperature": 0.7, "max_tokens": 4096 },
  "compat": {
    "supports_store": false,
    "max_tokens_field": "max_tokens",
    "thinking_format": "none",
    "supports_prompt_cache": true,
    "stream_includes_usage": false
  },
  "auth": {
    "method": "none",
    "required": false
  },
  "cache_policy": { "mode": "short", "breakpoint_cap": 4 },
  "tool_compat": {
    "tool_call_id_rules": { "max_length": 40, "alphabet": "[a-zA-Z0-9_-]" },
    "schema_sanitizer": "openai",
    "supports_parallel_tool_calls": true
  },
  "error_rules": {
    "retryable_statuses": [429, 500, 502, 503, 504],
    "context_overflow_patterns": [
      "greater than the context length"
    ]
  }
}
